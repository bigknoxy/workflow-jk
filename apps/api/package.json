{
  "name": "@workflow-jk/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=verbose"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@workflow-jk/adapters": "workspace:*",
    "@workflow-jk/application": "workspace:*",
    "@workflow-jk/config": "workspace:*",
    "@workflow-jk/contracts": "workspace:*",
    "@workflow-jk/domain": "workspace:*",
    "@workflow-jk/observability": "workspace:*",
    "@workflow-jk/orchestration": "workspace:*",
    "@workflow-jk/testing": "workspace:*",
    "fastify": "^5.1.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "vitest": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}