# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database (required in production)
DATABASE_URL=postgresql://user:password@localhost:5432/workflow_jk

# Auth (required when AUTH_ENABLED=true)
AUTH_ENABLED=true
SESSION_SECRET=change-me-to-a-random-32-char-string

# CORS
CORS_ORIGIN=http://localhost:3000

# LLM Provider (fake|ollama|openai-compatible)
LLM_PROVIDER=fake

# OpenAI (required when LLM_PROVIDER=openai-compatible)
OPENAI_API_KEY=sk-...

# Observability
OBSERVABILITY_ENABLED=true
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# Workflow Safety
WORKFLOW_TIMEOUT_MS=3600000
AGENT_TIMEOUT_MS=120000
IDEMPOTENCY_TTL_SECONDS=86400