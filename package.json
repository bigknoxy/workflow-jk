{
  "name": "workflow-jk",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:eslint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:contract": "turbo run test:contract",
    "test:workflow": "turbo run test:workflow",
    "test:integration": "turbo run test:integration",
    "test:e2e": "turbo run test:e2e",
    "seed": "tsx packages/testing/src/seed.ts",
    "db:migrate": "tsx packages/adapters/src/db/migrate.ts",
    "eval": "bun run --cwd packages/evaluation src/run-eval.ts"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "@types/node": "^22.10.0",
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "typescript-eslint": "^8.18.0"
  }
}